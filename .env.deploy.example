# Локально: скопируй в .env.deploy (не коммить)
# CI: GitHub → Settings → Secrets and variables → Actions
#
# Secrets (обязательно):
#   SSH_PRIVATE_KEY   — приватный ключ ЦЕЛИКОМ (-----BEGIN ... END-----),
#                       без passphrase, без кавычек, одна строка = одна строка ключа
#   DEPLOY_HOST       — deploy@your-timeweb-server
#
# Если CI падает с libcrypto / invalid key — пересоздай ключ:
#   ssh-keygen -t ed25519 -f gayduk_deploy -N ""
#   публичный → authorized_keys на сервере
#   приватный → GitHub Secret (скопируй файл, не .pub)
#
# Variables (опционально, Repository variables):
#   VITE_AUDIO_PROXY_BASE=https://xn--80afepl7c.xn--p1ai/audio  — CI / .env.production
#   DEPLOY_WEB_ROOT=/var/www/gayduk
#   DEPLOY_PROXY_DIR=/opt/gayduk-audio-proxy
#   DEPLOY_PROXY_SERVICE=gayduk-audio-proxy
#   DEPLOY_OEMBED_DIR=/opt/gayduk-oembed
#   DEPLOY_OEMBED_SERVICE=gayduk-oembed
#
# На сервере: deploy/sudoers-gayduk-audio-proxy → /etc/sudoers.d/ (install + restart)

# SSH: пользователь@IP или пользователь@домен
DEPLOY_HOST=deploy@your-timeweb-server

# Каталог статики на сервере (nginx root)
DEPLOY_WEB_ROOT=/var/www/gayduk

# Опционально: обновлять audio-proxy при каждом deploy
DEPLOY_PROXY_DIR=/opt/gayduk-audio-proxy
DEPLOY_PROXY_SERVICE=gayduk-audio-proxy

DEPLOY_OEMBED_DIR=/opt/gayduk-oembed
DEPLOY_OEMBED_SERVICE=gayduk-oembed

# 0 — всегда scp (если нет rsync в Windows/Git Bash)
# DEPLOY_RSYNC=0
