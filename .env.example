# Прод: аудио с сервера (после npm run sync:media на VPS → /var/media)
VITE_MEDIA_BASE=/media

# Режим Яндекс.Диска + прокси (без локальных mp3):
# VITE_AUDIO_PROXY_BASE=https://your-audio-proxy.example.com
# Локально: npm run proxy:audio → VITE_AUDIO_PROXY_BASE=http://localhost:8787

# Яндекс.Метрика (счётчик). Без переменной аналитика отключена.
VITE_YM_COUNTER_ID=109337902
