# Сборка фронта: база URL аудио-прокси (без / в конце). Плеер подставляет ?url=...
# Прод: HTTPS от Serverless Containers / VM после деплоя Dockerfile.
VITE_AUDIO_PROXY_BASE=https://your-audio-proxy.example.com

# Локально: npm run proxy:audio, затем:
# VITE_AUDIO_PROXY_BASE=http://localhost:8787

# Яндекс.Метрика (счётчик). Без переменной аналитика отключена.
VITE_YM_COUNTER_ID=109337902
